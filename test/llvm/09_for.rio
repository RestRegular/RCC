// ============================================================================
// 测试9: for 循环
// 验证: for({init; cond; update}) { body } 语法
// 期望输出:
//   5050
//   3628800
// ============================================================================
// 累加 1..100
var sum = 0
for({var j = 1; j <= 100; j += 1}) {
    sum += j
}
sout(sum)

// 阶乘
var result = 1
for({var n = 1; n <= 10; n += 1}) {
    result *= n
}
sout(result)
