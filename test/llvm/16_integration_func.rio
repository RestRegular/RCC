// ============================================================================
// 测试16: 综合测试 — 函数式编程模式
// 验证: 高阶函数、lambda、递归的组合
// 期望输出:
//   15
//   120
//   55
//   10
//   49
//   82
// ============================================================================

// 累加 1..N
fun sumToN(n) {
    var sum = 0
    var i = 1
    while i <= n {
        sum += i
        i += 1
    }
    ret sum
}
sout(sumToN(5))

// 阶乘 (递归)
fun factorial(n) {
    if n <= 1 {
        ret 1
    }
    ret n * factorial(n - 1)
}
sout(factorial(5))

// 累加 1..10
sout(sumToN(10))

// Lambda 基础
var double = (n) -> { ret n * 2 }
sout(double(5))

var square = (x) -> { ret x * x }
sout(square(7))

// Lambda 组合
fun apply(f, x) {
    ret f(x)
}
var inc = (n) -> { ret n + 1 }
sout(apply(inc, square(9)))
