// ============================================================================
// 测试3: 算术运算
// 验证: +, -, *, /, %, 负号
// 期望输出:
//   7
//   3
//   21
//   2
//   1
//   -6
// ============================================================================
sout(3 + 4)
sout(10 - 7)
sout(3 * 7)
sout(10 / 4)
sout(10 % 3)

// 负号
sout(-6)
