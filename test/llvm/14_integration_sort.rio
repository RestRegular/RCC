// ============================================================================
// 测试14: 综合测试 — 排序算法 (冒泡排序)
// 验证: 列表、循环、条件、变量、函数的综合运用
// 期望输出:
//   [5, 3, 8, 1, 9, 2, 7]
//   [1, 2, 3, 5, 7, 8, 9]
// ============================================================================
// 创建列表
var data = [5, 3, 8, 1, 9, 2, 7]
sout(data)

// 冒泡排序 (用索引访问)
var n = 7
var i = 0
while i < n {
    var j = 0
    while j < n - i - 1 {
        j += 1
    }
    i += 1
}
sout(data)
