// ============================================================================
// 测试11: if / elif / else 条件
// 验证: 多分支条件判断
// 期望输出:
//   -1
//   0
//   1
//   2
//   3
// ============================================================================
fun classify(n) {
    if n < 0 {
        ret -1
    } elif n == 0 {
        ret 0
    } elif n < 10 {
        ret 1
    } elif n < 100 {
        ret 2
    } else {
        ret 3
    }
}

sout(classify(-5))
sout(classify(0))
sout(classify(3))
sout(classify(42))
sout(classify(200))
