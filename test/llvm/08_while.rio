// ============================================================================
// 测试8: while 循环
// 验证: while 基础循环、break、continue
// 期望输出:
//   5050
//   1
//   3
//   5
//   7
//   9
//   5
// ============================================================================
// 累加 1..100
var sum = 0
var i = 1
while i <= 100 {
    sum += i
    i += 1
}
sout(sum)

// continue: 只打印奇数
var m = 0
while m < 10 {
    m += 1
    if m % 2 == 0 {
        continue
    }
    sout(m)
}

// break: 在 5 处中断
var k = 0
while k < 10 {
    k += 1
    if k == 5 {
        break
    }
}
sout(k)
