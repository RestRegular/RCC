// ============================================================================
// 测试15: 综合测试 — 数学计算 (斐波那契、素数、最大公约数)
// 验证: 递归、循环、条件判断的组合
// 期望输出:
//   55
//   6765
//   12
//   1
// ============================================================================
// 斐波那契数列
fun fib(n) {
    if n <= 1 {
        ret n
    }
    ret fib(n - 1) + fib(n - 2)
}
sout(fib(10))

// 迭代斐波那契 (更快)
fun fibIter(n) {
    if n <= 1 {
        ret n
    }
    var a = 0
    var b = 1
    var i = 2
    while i <= n {
        var temp = a + b
        a = b
        b = temp
        i += 1
    }
    ret b
}
sout(fibIter(20))

// 最大公约数 (欧几里得算法)
fun gcd(a, b) {
    if b == 0 {
        ret a
    }
    ret gcd(b, a % b)
}
sout(gcd(48, 36))

// 素数判断
fun isPrime(n) {
    if n < 2 {
        ret 0
    }
    var i = 2
    while i * i <= n {
        if n % i == 0 {
            ret 0
        }
        i += 1
    }
    ret 1
}
sout(isPrime(17))
sout(isPrime(15))
