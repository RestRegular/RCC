// ============================================================================
// 测试10: until 循环 (do-while 语义)
// 验证: until condition { body } — 先执行后判断
// 期望输出:
//   1
//   2
//   3
//   4
//   5
//   done
// ============================================================================
var n = 1
until n > 5 {
    sout(n)
    n += 1
}
sout("done")
