// ============================================================================
// 测试2: 变量定义与赋值
// 验证: var 定义、重新赋值、复合赋值运算符
// 期望输出:
//   30
//   200
//   10
//   2
//   0
//   8
//   7
//   28
//   14
//   2
// ============================================================================
var a = 10
var b = 20
var c = a + b
sout(c)
sout(a * b)
sout(b - a)
sout(b / a)
sout(b % a)

// 复合赋值
var x = 5
x += 3
sout(x)
x -= 1
sout(x)
x *= 4
sout(x)
x /= 2
sout(x)
x = x % 3
sout(x)
