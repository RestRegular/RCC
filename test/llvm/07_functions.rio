// ============================================================================
// 测试7: 函数定义与调用
// 验证: 多参数函数、递归、嵌套调用
// 期望输出:
//   7
//   3628800
//   55
//   120
// ============================================================================
fun add(a, b) {
    ret a + b
}

fun factorial(n) {
    if n <= 1 {
        ret 1
    }
    ret n * factorial(n - 1)
}

fun fib(n) {
    if n <= 1 {
        ret n
    }
    ret fib(n - 1) + fib(n - 2)
}

sout(add(3, 4))
sout(factorial(10))

// 累加 1..10
fun sumRange(n) {
    if n <= 0 {
        ret 0
    }
    ret n + sumRange(n - 1)
}
sout(sumRange(10))

// 嵌套调用
sout(factorial(add(3, 2)))
