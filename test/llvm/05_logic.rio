// ============================================================================
// 测试5: 逻辑运算 (短路求值)
// 验证: &&, ||, !
// 期望输出:
//   1
//   0
//   1
//   0
//   1
//   0
//   0
//   1
// ============================================================================
sout(true && true)
sout(true && false)
sout(false || true)
sout(false || false)
sout(!true)
sout(!false)

// 短路求值测试
var x = 0
false && (x = 1)
sout(x)
true || (x = 2)
sout(x)
