// 最简类测试：只测试定义和实例化，不测试方法调用

class Point {
    var x: int, y: int, z: str

    ctor(a: int, b: int, z: str) {
        this.x = a
        this.y = b
        this.z = z
    }
}

fun main(): void {
    var p = Point(10, 20, "test point")
    sout("p.x = ", p.x)
    sout("p.y = ", p.y)
    sout("p.z = ", p.z)
}

main()
