// ============================================================================
// 测试 15: 综合测试
// 验证: 多种特性组合使用
// ============================================================================
fun fib(n) {
    if n <= 1 {
        ret n
    }
    ret fib(n - 1) + fib(n - 2)
}

fun main() {
    var results = []
    var i = 0
    while i < 10 {
        results += fib(i)
        i += 1
    }
}
