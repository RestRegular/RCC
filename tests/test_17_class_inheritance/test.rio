// 最简继承测试：只测试继承和 super

class Base {
    var val: int

    ctor(v: int) {
        this.val = v
    }
}

class Derived: Base {
    var extra: int

    ctor(v: int, e: int) {
        super(v)
        this.extra = e
    }
}

fun main(): void {
    var d = Derived(42, 99)
    sout(d.val)
    sout(d.extra)
}
