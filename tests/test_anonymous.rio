// ============================================================================
// 测试 8: 匿名函数
// 验证: 匿名函数定义和调用
// ============================================================================

// 匿名函数赋值给变量
var add = (a, b) -> { ret a + b }
var result = add(3, 5)

// 直接调用匿名函数
var double = (x) -> { ret x * 2 }
var doubled = double(10)

// 匿名函数作为参数
fun apply(f, x) {
    ret f(x)
}

var applied = apply((n) -> { ret n * n }, 5)
