// ============================================================================
// 测试 10: 类定义和使用
// 验证: 类声明、类定义、构造函数、成员变量、方法
// ============================================================================

// 类定义
class Point {
    var x, y

    ctor(x, y) {
        this.x = x
        this.y = y
    }

    fun distance() {
        ret this.x * this.x + this.y * this.y
    }
}

// 创建实例
var p = Point(3, 4)
var dist = p.distance()
