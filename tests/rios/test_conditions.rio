// ============================================================================
// 测试 4: 条件语句 (if-elif-else)
// 验证: if 单分支、if-else、if-elif-else、嵌套 if
// ============================================================================
fun sout(*args, end="\n"): void {
    encapsulated
}

var x = 10

// if 单分支
if x > 5 {
    var a = 1
    sout("if-single: pass")
}

// if-else
if x > 20 {
    sout("if-else: FAIL")
} else {
    sout("if-else: pass")
}

// if-elif-else
var grade = 85
if grade >= 90 {
    sout("elif: FAIL-A")
} elif grade >= 80 {
    sout("elif: pass-B")
} elif grade >= 70 {
    sout("elif: FAIL-C")
} else {
    sout("elif: FAIL-D")
}

// 嵌套 if
if x > 0 {
    if x > 5 {
        sout("nested: pass-big")
    } else {
        sout("nested: FAIL-small")
    }
}
