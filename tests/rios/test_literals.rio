// ============================================================================
// 测试 1: 字面量和基本运算
// 验证: 整数、浮点、布尔、字符串、字符、null 字面量
// 验证: 算术运算 (+, -, *, /, %, //, **)
// ============================================================================
fun sout(*args, end="\n"): void {
    encapsulated
}

var a = 10
var b = 3.14
var c: str = true
var d = "hello"
var e = "x"
var f = null

var sum = a + 5
var diff = a - 3
var product = a * 2
var quotient = a / 3
var remainder = a % 3
var power = a ** 2

sout(a, " ", b, " ", c, " ", d, " ", e, " ", f)
sout(sum, " ", diff, " ", product, " ", quotient, " ", remainder, " ", power)