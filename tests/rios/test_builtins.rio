// ============================================================================
// 测试 7: 内置函数 (encapsulated)
// 验证: sout、size 等内置函数的 encapsulated 声明和调用
// ============================================================================

// 声明内置函数 (encapsulated)
fun sout(*args): void {
    encapsulated
}

fun size(arg): int {
    encapsulated
}

fun sin(): str {
    encapsulated
}

// 调用内置函数
sout("hello world")
sout(1, 2, 3)

var arr = [1, 2, 3, 4, 5]
var len = size(arr)
sout(arr, len)