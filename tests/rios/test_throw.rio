// ============================================================================
// 测试 13: throw
// 验证: throw 表达式
// ============================================================================
fun sout(*args, end="\n"): void {
    encapsulated
}

fun safeDivide(a, b) {
    if b == 0 {
        throw "division by zero"
    }
    ret a / b
}

sout(safeDivide(10, 3))
sout("throw test: before throw")
